{
  "name": "learncrosswords-backend",
  "version": "1.0.0",
  "description": "Backend API for Learn Crosswords",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "seed:words": "ts-node src/seeds/seedWords.ts",
    "seed:clear": "ts-node src/seeds/clearPuzzles.ts",
    "generate:puzzles": "ts-node src/seeds/generatePuzzles.ts",
    "generate:all": "npm run seed:words && npm run seed:clear && npm run generate:puzzles",
    "generate:beginner": "ts-node src/seeds/generatePuzzles.ts --only=beginner",
    "generate:intermediate": "ts-node src/seeds/generatePuzzles.ts --only=intermediate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@sentry/node": "^10.42.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crossword-layout-generator": "^0.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.3",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.6",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
